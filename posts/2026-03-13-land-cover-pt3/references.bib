	month = dec,
	year = {2019},
	pmid = {39886693},
	pmcid = {PMC11781567},
	pages = {209--234},
	file = {Full Text PDF:C\:\\Users\\krist108\\Zotero\\storage\\AMNI8XGN\\Kugler et al. - 2019 - People and Pixels 20 years later the current data landscape and research trends blending population.pdf:application/pdf},
